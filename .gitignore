# Lockfiles — npm only (`package-lock.json` is canonical). Do not commit Yarn/Bun/pnpm locks.
pnpm-lock.yaml
yarn.lock
bun.lock
bun.lockb

# Logs
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

node_modules
dist
dist-ssr
*.local

# Environment (secrets — never commit)
.env
.env.*
!.env.example

# Editor directories and files
.vscode/*
!.vscode/extensions.json
.idea
.DS_Store
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# Supabase local temp/state artifacts
supabase/.temp/

# Claude Code local files
.claude/

# Build-generated sitemaps & prerender data
# (regenerated by scripts/seo/generate-sitemaps.mjs)
# Keep tracked: public/sitemaps/static.xml (stable static routes)
/public/sitemap.xml
/public/sitemaps/prerender-routes.json
/public/sitemaps/listings-*.xml
/public/sitemaps/agencies-*.xml
/public/sitemaps/listings-prerender-data.json
/public/sitemaps/listings-prerender-data-cache.json
/public/sitemaps/agencies-prerender-data.json
/public/sitemaps/agencies-prerender-data-cache.json
/public/sitemaps/listings-html-data.jsonl
/public/sitemaps/listings-html-data-cache.jsonl
