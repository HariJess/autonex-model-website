# Variables d'environnement locales (gitignored — ne JAMAIS committer .env.local).
# Copier ce fichier vers .env.local et renseigner les valeurs sensibles.

# --- Pipeline d'extraction LLM (sprint 2 — annonces FB → tuples structurés) ---

# Clé API Anthropic — extraction LLM des annonces FB.
# Récupérer une clé sur https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-api03-...

# Modèle primaire (claude-haiku-4-5 par défaut, claude-sonnet-4-5 pour cas complexes).
# Si haiku-4-5 indisponible, fallback acceptable: claude-3-5-haiku-20241022
ANTHROPIC_MODEL_PRIMARY=claude-haiku-4-5
ANTHROPIC_MODEL_FALLBACK=claude-sonnet-4-5

# Budget plafond local en USD — le batch s'arrête si dépassé.
LLM_BUDGET_USD_MAX=5
