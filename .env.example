# Copier ce fichier vers `.env` et renseigner les valeurs (voir Supabase Dashboard > Project Settings > API).
# Le fichier `.env` est ignoré par git ; ne committez jamais de secrets.

# --- Obligatoire pour l’app React (Auth, données, Storage) ---
VITE_SUPABASE_URL="https://votre-ref.supabase.co"
VITE_SUPABASE_PUBLISHABLE_KEY="votre-anon-key"

# --- Optionnel ---
# Canon du site pour SEO / URLs absolues (fallback interne sinon).
# VITE_SITE_URL="https://autonex.mg"

# Monitoring Sentry — laisser vide pour désactiver (le SDK reste no-op).
# DSN trouvé dans Sentry > Project Settings > Client Keys (DSN).
# VITE_SENTRY_DSN=""
# VITE_SENTRY_ENVIRONMENT="development"
# VITE_SENTRY_RELEASE=""

# Google Analytics 4 — Measurement ID au format G-XXXXXXXXXX.
# Laisser vide pour désactiver GA4 (le SDK n'est alors jamais chargé).
# Nécessite ALSO le consentement analytics de l'utilisateur via la bannière cookies.
# VITE_GA4_MEASUREMENT_ID="G-XXXXXXXXXX"

# Scripts Node hors navigateur uniquement (ingestion marché, certains scripts catalog) —
# ne pas exposer dans le frontend : utiliser `.env.local` ou l’env du CI.
# SUPABASE_SERVICE_ROLE_KEY=""

# Feature flag: show legacy manual payment UI (MVola/Orange/Airtel/bank transfer + proof upload).
# Default false since P.3 ships VPI (Vanilla Pay). Set to "true" for admin fallback / debugging.
# VITE_ENABLE_MANUAL_PAYMENT="false"

# Beta payment banner — show warning on /credits and /paiement/retour during first 72h of VPI rollout.
# Set to "false" after stability confirmed post-launch.
# VITE_PAYMENT_BETA_BANNER_ENABLED="true"
